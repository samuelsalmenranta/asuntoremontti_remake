---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactForm from '~/components/ContactForm.astro';
import ProcessSteps from '~/components/ProcessSteps.astro';
import FAQ from '~/components/FAQ.astro';
import { services, site } from '~/data/site';
import type { Service } from '~/data/site';

export async function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props { service: Service }
const { service } = Astro.props;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: service.name,
  provider: {
    '@type': 'HomeAndConstructionBusiness',
    name: site.name,
    telephone: site.phone,
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.address.street,
      postalCode: site.address.postalCode,
      addressLocality: site.address.city,
      addressCountry: site.address.country,
    },
  },
  areaServed: [
    { '@type': 'City', name: 'Lahti' },
    { '@type': 'AdministrativeArea', name: site.address.region },
  ],
  name: service.shortName,
  description: service.metaDescription,
};
---
<BaseLayout
  title={service.titleTag}
  description={service.metaDescription}
  canonicalPath={`/palvelut/${service.slug}/`}
  breadcrumbSchema={[
    { name: 'Etusivu', url: '/' },
    { name: 'Palvelut', url: '/palvelut/' },
    { name: service.name, url: `/palvelut/${service.slug}/` },
  ]}
>
  <!-- HERO -->
  <section class="hero" style="padding-block: clamp(48px, 6vw, 96px) clamp(32px, 5vw, 64px);">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Etusivu</a><span class="breadcrumb__sep">/</span>
        <a href="/palvelut/">Palvelut</a><span class="breadcrumb__sep">/</span>{service.name}
      </div>
      <div class="eyebrow" style="margin-bottom:16px;">Palvelu · Lahti & Päijät-Häme</div>
      <h1 style="max-width:22ch; margin-bottom:24px;">{service.heroTitle}</h1>
      <p style="font-size:clamp(var(--fs-lg), 2vw, var(--fs-xl)); color:var(--ink-2); max-width:60ch; margin-bottom:32px;">
        {service.heroLead}
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:12px;">
        <a href="/yhteystiedot/" class="btn btn--primary">Pyydä tarjous</a>
        <a href={`tel:${site.phone}`} class="btn btn--outline">Soita {site.phoneDisplay}</a>
      </div>
    </div>
  </section>

  <!-- SISÄLTÖ -->
  <section class="section section--soft">
    <div class="container">
      <div class="grid-2" style="align-items:start;">
        <div>
          <div class="eyebrow" style="margin-bottom:12px;">Mitä sisältyy</div>
          <h2 style="margin-bottom:24px;">Näin toteutan {service.name.toLowerCase()}n</h2>
          <p style="color:var(--ink-2); margin-bottom:32px;">
            Hoidan koko projektin alusta loppuun. Sinun ei tarvitse koordinoida erillisiä tekijöitä.
          </p>
          <ul class="checklist">
            {service.includes.map(i => <li>{i}</li>)}
          </ul>
        </div>

        <div>
          <div style="background:var(--surface); border:1px solid var(--line); border-radius:var(--radius-lg); padding:28px; margin-bottom:24px;">
            <div class="eyebrow" style="margin-bottom:8px;">Tyypillinen aikataulu</div>
            <div style="font-family:var(--font-display); font-size:var(--fs-2xl); font-weight:600; color:var(--ink); margin-bottom:16px; letter-spacing:-0.02em;">
              {service.duration}
            </div>
            <p style="color:var(--ink-2); font-size:var(--fs-sm); margin-top:12px;">
              Tarkka aikataulu riippuu kohteesta. Soita tai jätä viesti, niin kerron tarkemmin.
            </p>
          </div>

          <div class="callout">
            <p>
              <strong>Kotitalousvähennys.</strong> {service.name} on kotitalousvähennykseen oikeutettu työtä.
              Erittelemme työn ja materiaalit tarjoukseen, jotta vähennys on helppo hakea.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROSESSI -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <div class="eyebrow" style="margin-bottom:12px;">Prosessi</div>
          <h2 class="section-heading__title">Selkeä kulku alusta loppuun.</h2>
        </div>
        <p class="section-heading__lead">
          Kerron aina etukäteen mitä tehdään ja missä aikataulussa.
        </p>
      </div>
      <ProcessSteps />
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={service.faq} title={`${service.name} — usein kysyttyä`} />

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="grid-2">
        <div>
          <div class="eyebrow" style="margin-bottom:12px;">Yhteydenotto</div>
          <h2 style="max-width:22ch;">Kiinnostuitko? Pyydä tarjous.</h2>
          <p style="color:var(--ink-3); margin-top:16px; max-width:44ch;">
            Soita tai jätä viesti, niin palataan asiaan.
          </p>
          <p style="margin-top:24px;">
            <a href={`tel:${site.phone}`} style="color:var(--bg); font-family:var(--font-display); font-size:var(--fs-xl); text-decoration:none;">
              📞 {site.phoneDisplay}
            </a>
          </p>
        </div>
        <div style="background:var(--surface); color:var(--ink); padding:32px; border-radius:var(--radius-lg);">
          <ContactForm defaultService={service.slug} />
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
</BaseLayout>
