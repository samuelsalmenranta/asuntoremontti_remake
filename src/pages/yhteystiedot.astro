---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactForm from '~/components/ContactForm.astro';
import { site } from '~/data/site';

const title = 'Yhteystiedot | Pyydä tarjous | asuntoremontti.fi';
const description = `Ota yhteyttä: ${site.phoneDisplay} tai ${site.email}. ${site.address.street}, ${site.address.postalCode} ${site.address.city}.`;
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/yhteystiedot/"
  includeLocalBusinessSchema={true}
  breadcrumbSchema={[
    { name: 'Etusivu', url: '/' },
    { name: 'Yhteystiedot', url: '/yhteystiedot/' },
  ]}
>
  <section class="section">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Etusivu</a><span class="breadcrumb__sep">/</span>Yhteystiedot
      </div>
      <div class="eyebrow" style="margin-bottom:16px;">Yhteystiedot</div>
      <h1 style="max-width:20ch; margin-bottom:24px;">Ota yhteyttä.</h1>
      <p style="font-size:var(--fs-lg); color:var(--ink-2); max-width:56ch; margin-bottom:48px;">
        Soita tai jätä viesti, niin palataan asiaan.
      </p>

      <div class="grid-2" style="align-items:start;">
        <div>
          <h2 style="margin-bottom:24px;">Yhteystiedot</h2>

          <div style="display:grid; gap:20px; margin-bottom:32px;">
            <div>
              <div class="eyebrow" style="margin-bottom:6px;">Puhelin</div>
              <a href={`tel:${site.phone}`} style="font-family:var(--font-display); font-size:var(--fs-2xl); font-weight:600; color:var(--ink); text-decoration:none; letter-spacing:-0.02em;">
                {site.phoneDisplay}
              </a>
            </div>

            <div>
              <div class="eyebrow" style="margin-bottom:6px;">Sähköposti</div>
              <a href={`mailto:${site.email}`} style="font-family:var(--font-display); font-size:var(--fs-xl); color:var(--ink); text-decoration:none;">
                {site.email}
              </a>
            </div>

            <div>
              <div class="eyebrow" style="margin-bottom:6px;">Toimipiste</div>
              <address style="font-style:normal; font-size:var(--fs-lg);">
                {site.legalName}<br />
                {site.address.street}<br />
                {site.address.postalCode} {site.address.city}
              </address>
            </div>

            <div>
              <div class="eyebrow" style="margin-bottom:6px;">Y-tunnus</div>
              <div style="font-family:var(--font-mono);">{site.vatId.replace('FI','')}</div>
            </div>
          </div>

          <div class="callout">
            <p><strong>Palvelualue.</strong> Lahti, Hollola, Nastola, Orimattila, Heinola, Asikkala.</p>
          </div>
        </div>

        <div style="background:var(--surface); border:1px solid var(--line); border-radius:var(--radius-lg); padding:32px;">
          <h2 style="margin-bottom:8px; font-size:var(--fs-2xl);">Jätä viesti</h2>
          <p style="color:var(--ink-2); font-size:var(--fs-sm); margin-bottom:24px;">
            Kerro lyhyesti mitä remontoit, niin otan yhteyttä.
          </p>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
